# Soulkiller OSS candidate environment

# Core paths
SOULKILLER_DATA_DIR=./runtime
SOULKILLER_DEMO_DIR=./demo
SOULKILLER_SCRIPTS_DIR=

# Hook configuration (OpenClaw integration)
OPENCLAW_HOME=
OPENCLAW_BIN=openclaw
SOULKILLER_FOLLOWUP_CRON=soulkiller:checkin-followup

# Optional subject configuration
SOULKILLER_SUBJECT_ID=demo-subject
SOULKILLER_SUBJECT_NAME=Demo Subject

# Optional provider configuration
SOULKILLER_MODEL=
SOULKILLER_PROVIDER=

# Relational agent (agent ID used for passive observation and stress probes)
SOULKILLER_RELATIONAL_AGENT=
SOULKILLER_RELATIONAL_AGENT_IDS=

# Optional integration toggles
SOULKILLER_ENABLE_TELEGRAM=false
SOULKILLER_ENABLE_BIOFEEDBACK=false
SOULKILLER_ENABLE_MUSE=false

# Optional adapter credentials
SOULKILLER_ZEPP_EMAIL=
SOULKILLER_ZEPP_PASSWORD=

# Telegram integration (required if SOULKILLER_ENABLE_TELEGRAM=true or SOULKILLER_ENABLE_MUSE=true)
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGS_CHAT_ID=
TELEGRAM_LOGS_THREAD_ID=
